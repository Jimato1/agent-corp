# Board — environment template (real .env* files are gitignored — DEPLOYMENT §5).
# Values must match context/specs/DEPLOYMENT.md (never re-derive cross-cutting values).

NODE_ENV=production
BOARD_PORT=8080
BOARD_DB_PATH=/data/board.db
BOARD_BACKUP_DIR=/data/backups

# Auth RS baseline (auth at auth:8089 — the ONE correct verify port, DEPLOYMENT §4).
BOARD_AUTH_ISSUER=https://auth.example.com
BOARD_AUTH_JWKS_URL=http://auth:8089/.well-known/jwks.json
BOARD_AUTH_BUDGET_URL=http://auth:8089/budget/admission
BOARD_AUTH_REVOCATIONS_URL=http://auth:8089/revocations

# CORS allowlist for MC's browser-direct operator console (PLAN §17).
BOARD_MC_ORIGIN=https://mc.example.com

# Board-as-client upstreams (svc:board — notes:read + chat:post).
BOARD_NOTES_URL=http://notes:8080
BOARD_CMDB_URL=http://cmdb:8080
BOARD_CHAT_URL=http://chat:8080

# Wazuh kickoff webhook — static HMAC over the RAW body (D-9). REQUIRED in prod. NEVER logged.
BOARD_WAZUH_HMAC_SECRET=change-me-long-random

# CANONICAL-store off-box backup destination (ARCH §10). REQUIRED in prod.
BOARD_BACKUP_TARGET=/mnt/offbox/board-backups

# Outage-aware reaper (gap 4.4 / D-12). Keep BOARD_FLEET_SIZE truthful (PLAN §20.5).
BOARD_FLEET_SIZE=20
BOARD_OUTAGE_GATE_MIN_AGENTS=4
BOARD_OUTAGE_GATE_THRESHOLD=0.4

# Guardrails.
BOARD_WIP_GLOBAL_CAP=8
BOARD_WIP_PER_AGENT_CAP=1
BOARD_LINEAGE_MAX_DEPTH=3

# svc:tier-approver (D-15) — NON-ACTIVATABLE until auth admits kind=service for board:approve.
# Leave false: ALL approvals are operator-granted (safe degradation).
BOARD_TIER_APPROVER_ENABLED=false

# RESTORE mode — set to true for exactly ONE boot after restoring a backup (§16). NEVER on a normal restart.
BOARD_RESTORE_RECONCILE=false
