# pdf-forge — runtime knobs (STRUCTURE §6). All are namespaced PDFFORGE_.
# Copy to .env for local runs; in production set them in docker-compose.yml.

# Upload validation
PDFFORGE_MAX_UPLOAD_MB=200          # hard streaming cap -> 413 ; proxy body cap MUST be >= this
PDFFORGE_MAX_PAGE_COUNT=5000        # reject absurd page counts at validation

# Resource bounds (D3)
PDFFORGE_WORKER_COUNT=1             # ProcessPoolExecutor workers (1 on 2C/2G; up to 2)
PDFFORGE_QUEUE_MAXSIZE=8            # over-capacity submit -> 429 + Retry-After
PDFFORGE_JOB_TIMEOUT_SECONDS=300    # per-subprocess wall-clock
PDFFORGE_OCR_TIMEOUT_SECONDS=120    # ocrmypdf --tesseract-timeout
PDFFORGE_JOB_TTL_SECONDS=3600       # orphan sweep TTL -> expired
PDFFORGE_DISK_RESERVE_FACTOR=4      # free < factor x MAX_UPLOAD -> 507
PDFFORGE_RETRY_AFTER_SECONDS=30

# OCR language packs installed in the image
PDFFORGE_OCR_LANGUAGES=["eng","deu"]

# Paths (defaults match the image)
PDFFORGE_STATIC_DIR=/app/static
PDFFORGE_JOBS_DIR=/app/jobs

# Engine scratch on the bounded volume (D2)
TMPDIR=/app/jobs/tmp
OMP_THREAD_LIMIT=1

# Frontend build-time gate (Vite)
VITE_CLIENT_SERVER_THRESHOLD_MB=150
