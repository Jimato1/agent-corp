# gateway — env template (DEPLOYMENT §5). Real .env* files are gitignored. Values must match
# the authoritative values in context/specs/DEPLOYMENT.md — never re-derived.
GATEWAY_PORT=8080
# D-8: gateway-PRIVATE Postgres. Isolated build/tests use sqlite:///data/gateway.sqlite3.
GATEWAY_DB_URL=postgresql://gw_app@gateway_postgres:5432/gateway
GATEWAY_SIGNING_KEY_FILE=/run/secrets/gateway_audit_key
GATEWAY_CHAIN_ID=gw-main

# The four holders + Notes + MC (fail-closed: unset => that leg is unreachable => refuse).
GATEWAY_BOARD_URL=http://board:8080
GATEWAY_CMDB_URL=http://cmdb:8080
GATEWAY_VAULT_URL=https://vault:8080
GATEWAY_NOTES_URL=http://notes:8080
GATEWAY_MC_URL=http://mc:8080

# auth RS baseline + destructive-exec live check (auth §8 step 7).
GATEWAY_AUTH_ISSUER=https://auth.suite.local/
GATEWAY_AUTH_JWKS_URL=http://auth:8089/jwks
GATEWAY_AUTH_AUDIENCE=gateway
GATEWAY_INTROSPECT_URL=http://auth:8089/introspect
AUTH_VERIFY_PORT=8089
SUITE_DOMAIN=suite.local

# creds-mTLS hop (svc:gateway; cnf = mTLS x5t#S256, §13).
GATEWAY_SVC_TOKEN_FILE=/run/secrets/gateway_svc_token
GATEWAY_VAULT_MTLS_CERT_FILE=/run/secrets/gateway_client_cert
GATEWAY_VAULT_MTLS_KEY_FILE=/run/secrets/gateway_client_key
GATEWAY_VAULT_CA_FILE=/run/secrets/vault_ca

# Wazuh connector (read-only; endpoints only — credentials are Vault handles).
GATEWAY_WAZUH_ENABLED=true
GATEWAY_WAZUH_INDEXER_URL=https://wazuh-indexer:9200
GATEWAY_WAZUH_API_URL=https://wazuh:55000

# Sandbox (D-7; tier-0).
GATEWAY_SANDBOX_POOL_HOST_ID=sbx-pool-01

# NEVER true in production (fail-closed escape hatches for the isolated build only):
# GATEWAY_ALLOW_UNCHECKABLE_DESTRUCTIVE=false
# GATEWAY_FAKE_RUNNER=false
