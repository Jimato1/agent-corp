# chat — environment template (real .env* files are gitignored, DEPLOYMENT §5).
# Chat-owned knobs are CHAT_-prefixed; SUITE_DOMAIN and AUTH_VERIFY_PORT are the
# cross-cutting values minted once in DEPLOYMENT §5 and consumed BY NAME.

# ---- cross-cutting (consumed by name, not re-derived) ----
SUITE_DOMAIN=suite.local
AUTH_VERIFY_PORT=8089

# ---- auth RS baseline ----
CHAT_AUTH_ISSUER=https://auth.suite.local/
CHAT_AUTH_JWKS_URL=http://auth:8089/jwks
CHAT_AUTH_AUDIENCE=chat
# CHAT_AUTH_TEST_HS256_SECRET=   # LEAVE EMPTY in prod — test-only symmetric signer

# ---- canonical store (ARCH §10) ----
CHAT_DB_PATH=/app/data/chat.sqlite3
CHAT_BACKUP_DIR=/app/data/backups
CHAT_DB_SIZE_GUARD_GB=2.0

# ---- push sink (ntfy is a SINK ONLY; no identity logic) ----
CHAT_NTFY_URL=http://chat_ntfy:80
CHAT_NTFY_TOPIC=chat
CHAT_NTFY_TOKEN=            # Chat's single write token (create via `ntfy token add`)
CHAT_NTFY_ENABLED=true

# ---- abuse controls ----
CHAT_RATE_POST_PER_HOUR=60
CHAT_RATE_ESCALATION_PER_HOUR=10
CHAT_ESCALATION_REPUSH_SECONDS=900
