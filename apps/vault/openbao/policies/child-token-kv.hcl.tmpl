# =============================================================================
# child-token-kv.hcl.tmpl — per-host KV child-token policy TEMPLATE
# =============================================================================
# Implements VERBATIM:  PLAN §2.1 (per-host num_uses=1 child token; kv side).
#
# The wrapper substitutes <HOST_ID> with the D-4-VERIFIED request host_id (never
# anything the token carries) to produce a named policy `child-kv-<HOST_ID>`,
# instantiated via the change-control path and referenced by the `redeem-child`
# token role's allowed_policies_glob = "child-kv-*" (see redeem-login.hcl / bootstrap.sh).
#
# GRANT: exactly ONE — read the current host's KV credential subtree. NO update,
# NO delete, NO metadata, NO other host. NO WILDCARD host (the CVE-2026-3605 /
# host-A-cannot-touch-host-B invariant, PLAN §2.1 / §3.5). The single-use bound
# is num_uses=1 SET ON THE TOKEN at create time (auth/token/create/redeem-child),
# NOT expressible in the policy — the policy is read-only-scoped, the TOKEN is
# single-use.
# =============================================================================

path "kv/data/hosts/<HOST_ID>/*" {
  capabilities = ["read"]
}
