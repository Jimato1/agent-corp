# Vault — environment template (real .env* files are gitignored — DEPLOYMENT §5).
# Values must match context/specs/DEPLOYMENT.md. Env prefix VAULT_ — but NEVER the literal VAULT_ADDR
# (it collides with HashiCorp-client convention); pinned names per PLAN §1.

NODE_ENV=production
VAULT_PORT=8080
VAULT_DB_PATH=/data/vault.db
VAULT_BACKUP_DIR=/data/backups

# --- creds mTLS listener (the Gateway-only redeem seam) ------------------------------------------
# A SPECIFIC address on the `creds` subnet — NEVER unset or 0.0.0.0 (MI-8; the wrapper refuses to boot).
VAULT_REDEEM_BIND=10.20.0.5:8443
VAULT_REDEEM_PORT=8443
VAULT_CERT_DIR=./secrets/vault
VAULT_GATEWAY_CLIENT_CN=svc:gateway

# --- auth RS baseline (auth at auth:8089 — the ONE correct verify port, DEPLOYMENT §4) -----------
VAULT_AUTH_ISSUER=https://auth.example.com
VAULT_AUTH_JWKS_URL=http://auth:8089/.well-known/jwks.json
VAULT_AUTH_INTROSPECT_URL=http://auth:8089/introspect
VAULT_AUTH_REVOCATIONS_URL=http://auth:8089/revocations
VAULT_AUTH_BUDGET_URL=http://auth:8089/budget/admission

# --- svc:vault D-4 Board facts re-verification + Chat escalation ---------------------------------
VAULT_BOARD_FACTS_URL=http://board:8080
VAULT_CHAT_URL=http://chat:8080

# --- OpenBao engine + unsealer (data_vault only; DEPLOYMENT §3a) ---------------------------------
VAULT_OPENBAO_ADDR=https://vault_openbao:8200
VAULT_UNSEALER_ADDR=https://vault_unsealer:8200
# The Transit auto-unseal token for the engine's seal stanza (orphan+periodic; §7.1). SECRET — never logged.
VAULT_TRANSIT_SEAL_TOKEN=change-me-transit-token

# --- off-box audit + DR (D-16) -------------------------------------------------------------------
# Hardened log host (WORM). REQUIRED in prod — redemption fails closed on auditability (D-16a).
VAULT_WORM_SINK_URL=https://worm-log-host.internal:9443/ingest
# Off-box, non-suite raft-snapshot destination (§7.3). REQUIRED in prod.
VAULT_SNAPSHOT_DEST=/mnt/offbox/vault-snapshots

# --- credential brokering knobs ------------------------------------------------------------------
VAULT_SSH_CERT_TTL=10m            # band 5-15 min, sized to one run (contract §2)
VAULT_RELEASE_TTL_MS=86400000     # pending-release TTL (24h)
VAULT_REDEEM_WINDOW_MS=900000     # W — binds the FIRST redemption only (B-4)
