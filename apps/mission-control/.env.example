# mission-control (mc) — committed env template. Real .env is gitignored (DEPLOYMENT §5).
# Cross-cutting values (SUITE_DOMAIN, AUTH_VERIFY_PORT) are consumed BY NAME (no MC_ prefix).

SUITE_DOMAIN=suite.local
AUTH_VERIFY_PORT=8089

# auth RS baseline (auth-apps-tokens-scopes.md §1)
MC_AUTH_ISSUER=https://auth.suite.local/
MC_AUTH_JWKS_URL=http://auth:8089/jwks
MC_AUTH_AUDIENCE=mc
MC_AUTH_BASE_URL=http://auth:8089

# Board composition reads
MC_BOARD_BASE_URL=http://board:8080

# The DEDICATED mc budget/WIP store — mc-private (data_mc). MUST NOT be auth's Redis (data_auth);
# the app REFUSES a URL that resolves to auth's private store at construction.
MC_BUDGET_REDIS_URL=redis://mc_redis:6379/0

# Edge observability sidecars (D-10)
MC_PROMETHEUS_URL=http://mc_prometheus:9090
MC_BLACKBOX_URL=http://mc_blackbox:9115
MC_LOGSTORE_URL=http://mc_logstore:3100

# agent-runtime heartbeat SSE producer (MC consumes it; empty => passive/honest-empty fleet)
MC_RUNTIME_SSE_URL=

# Isolated-build test signer ONLY — leave EMPTY in production (real JWKS validates EdDSA/ES256).
MC_AUTH_TEST_HS256_SECRET=
