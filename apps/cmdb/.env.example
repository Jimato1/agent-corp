# cmdb — example env (DEPLOYMENT §5: real .env* files are gitignored).
# Cross-cutting values (SUITE_DOMAIN, AUTH_VERIFY_PORT) are consumed by name, not prefixed.

SUITE_DOMAIN=suite.local
AUTH_VERIFY_PORT=8089

# auth RS baseline
CMDB_AUTH_ISSUER=https://auth.suite.local/
CMDB_AUTH_JWKS_URL=http://auth:8089/jwks
CMDB_AUTH_AUDIENCE=cmdb

# Stores
CMDB_DB_PATH=/app/data/cmdb.sqlite3
CMDB_POLICY_REPO_PATH=/app/policy
CMDB_POLICY_REPO_REMOTE=origin
# ARCH §10: keep true in production; a local-only policy .git is a build failure.
CMDB_REQUIRE_REMOTE=true

# Verdict signing (CMDB-local Ed25519 key — a DIFFERENT trust root from auth)
CMDB_VERDICT_KEY_PATH=/app/data/verdict_ed25519.key
CMDB_VERDICT_KID=cmdb-verdict-1

# A11 seam — sod-critical live denylist check (auth-exposed API). Empty => FAIL CLOSED.
CMDB_REVOCATION_CHECK_URL=
# ISOLATED BUILD ONLY — never true in production:
# CMDB_ALLOW_UNCHECKABLE_SODCRITICAL=false

# Wazuh discovery feed (read-only RBAC: agent:read syscollector:read group:read)
CMDB_WAZUH_ENABLED=false
CMDB_WAZUH_URL=https://wazuh:55000
CMDB_WAZUH_USER=
CMDB_WAZUH_PASSWORD=

# Board escalation intake (D-6c). Empty => degraded-but-honest (queue locally).
CMDB_BOARD_ESCALATION_URL=
