# Notes — environment template (DEPLOYMENT §5: committed as .env.example; real .env is gitignored).
# Copy to .env and fill in. Every variable is prefixed NOTES_ (plus NODE_ENV).
# Values here are the config.js defaults unless marked REQUIRED.

# ============================================================================================
# REQUIRED — CORR-5: a configured off-box git remote is BOOT-REQUIRED.
# A local-only .git is a BUILD FAILURE (ARCHITECTURE §10 / PLAN §2.3). The service REFUSES to boot
# if this is unset. The Notes markdown corpus MUST push to a remote so one disk loss can't destroy
# the source of truth and its reversibility history together.
# ============================================================================================
NOTES_GIT_REMOTE_URL=            # e.g. https://git.example.com/agent-corp/notes-corpus.git  (REQUIRED)

# ---- git remote details / credentials (deploy-time secrets; never note-visible) ----------------
NOTES_GIT_REMOTE_NAME=origin
NOTES_GIT_BRANCH=main
NOTES_GIT_REMOTE_USER=           # username for the remote (or x-access-token)
NOTES_GIT_REMOTE_TOKEN=          # PAT / push token — a secret; keep out of git
# Push cadence (PLAN §2.3): debounce <=60s; ERROR + degraded /healthz past the lag alarm.
NOTES_PUSH_DEBOUNCE_MS=60000
NOTES_PUSH_LAG_ALARM_S=900
# Commit author identity is COSMETIC — the audit join key is the `Sub:` trailer, not author.email.
NOTES_GIT_AUTHOR_EMAIL=agent@notes.local
NOTES_GIT_COMMITTER_NAME=notes-service

# ---- service / storage layout (DEPLOYMENT §2/§5) ------------------------------------------------
NOTES_PORT=8080                  # suite convention; the proxy imports notes:8080
NOTES_CORPUS_PATH=/data/corpus   # canonical markdown store == the git repo root
NOTES_DB_PATH=/data/index/notes.db   # the REBUILDABLE index — lives OUTSIDE the repo
NOTES_STATIC_DIR=/app/web-dist   # built web SPA served by src/api/static.js (set in the image)
NOTES_MAX_NOTE_BYTES=1048576     # per-note size cap (markdown only; artifacts belong to Drive)

# ---- auth Resource-Server baseline (auth resolves at auth:8089; audience == notes exactly) -------
NOTES_AUTH_ISSUER=https://auth.local
NOTES_AUTH_JWKS_URL=http://auth:8089/.well-known/jwks.json
NOTES_AUTH_INTROSPECT_URL=http://auth:8089/introspect
NOTES_AUTH_BUDGET_URL=http://auth:8089/budget/admission
NOTES_AUTH_TOKEN_URL=http://auth:8089/oauth/token
NOTES_JWKS_POLL_S=30

# ---- Board seam (PLAN §9.3): Notes holds svc:notes (client-credentials, board:read ONLY) ---------
NOTES_BOARD_URL=http://board:8080
NOTES_SVC_CLIENT_ID=svc:notes
NOTES_SVC_CLIENT_KEY=            # path to the asymmetric client-assertion private key (PEM); a secret
NOTES_BOARD_TIMEOUT_MS=250       # live fence-read timeout — fail-closed on timeout (CORR-6)

# ---- limits / behavior --------------------------------------------------------------------------
NOTES_LOCAL_CONCURRENCY=32       # in-process per-principal concurrency ceiling (Redis-independent)
NOTES_MECHANICAL_ISOLATION=false # draft-isolation variant — dormant until the Board↔Notes contract ratifies it
NOTES_HYGIENE_SALT=              # per-deployment salt for hygiene salted-hashes (set to a random value)
NOTES_LOG_LEVEL=info             # debug | info | warn | error

# ---- DANGEROUS: dev/test ONLY -------------------------------------------------------------------
# Bypasses OAuth entirely and takes the principal from X-Dev-Sub / X-Dev-Scopes headers.
# NEVER set this in production.
NOTES_DEV_UNSAFE_NO_AUTH=false

NODE_ENV=production
