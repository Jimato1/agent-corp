{
  "name": "@helm/drive",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Drive — the artifact store for every non-markdown output of agent work, keyed by ticket. Filesystem CAS + SQLite (D-14).",
  "engines": {
    "node": ">=22.5.0"
  },
  "bin": {
    "drive": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node --import tsx src/index.ts",
    "cli": "node --import tsx src/cli.ts",
    "test": "node --import tsx --test test/**/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "fastify": "^5.2.1",
    "jose": "^5.9.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.7",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
