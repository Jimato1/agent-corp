# Drive — Stage-4 environment (authoritative values per PLAN §11 + DEPLOYMENT §2/§5).
# Real .env* files are gitignored. This template's values MUST match PLAN/DEPLOYMENT.

# --- Deployment (DEPLOYMENT.md §2/§5) ---
DRIVE_PORT=8080                      # internal port; edge network only, NO host ports
DRIVE_DATA_DIR=/data                 # volume drive_data mount
DRIVE_DB_PATH=/data/db/drive.sqlite3

# In-cluster origin agent-facing byte refs are minted against (PLAN §2.2).
# Agents (agent-runtime) join `edge` and reach Drive directly here; full RS token
# validation still happens on Drive. Human refs use the subdomain origin.
DRIVE_INTERNAL_ORIGIN=http://drive:8080
DRIVE_PUBLIC_ORIGIN=https://drive.example.test

# --- auth RS baseline (auth-apps-tokens-scopes.md §1) ---
AUTH_VERIFY_HOST=auth
AUTH_VERIFY_PORT=8089                # the ONE correct value (DEPLOYMENT §4)
DRIVE_AUTH_ISSUER=https://auth.example.test
DRIVE_AUTH_JWKS_URL=http://auth:8089/.well-known/jwks.json
DRIVE_AUDIENCE=drive                 # aud == self, single-valued
# HS256 dev signer secret — ONLY for isolated build/test; production uses EdDSA JWKS.
DRIVE_DEV_HS256_SECRET=

# Verifies the proxy's signed X-Auth-Identity header for human/browser traffic.
# PEM (or JWKS url) of auth's identity-header signing key. Advisory headers are NEVER trusted.
DRIVE_IDENTITY_HEADER_JWKS_URL=http://auth:8089/.well-known/identity-jwks.json

# auth-exposed budget-check / admission API (DEPLOYMENT §3 S5 resolution — RSes never open auth's Redis).
DRIVE_BUDGET_API_URL=http://auth:8089/v1/budget/check
DRIVE_MAX_INFLIGHT=64                # Redis-independent in-process concurrency ceiling

# --- Board ticket-exists check (PLAN §2.1; svc:drive board:read) ---
# Degraded default (unverified_pending-always) until BOTH land: this grant activates
# AND the Board ticket-exists endpoint exists. Leave BOARD_API_URL empty to stay degraded.
DRIVE_BOARD_API_URL=
DRIVE_TICKET_CHECK_TTL=300           # seconds
DRIVE_TICKET_RECHECK_SCHEDULE=300,1800,7200,86400

# --- Limits / quotas / content policy (PLAN §10) ---
DRIVE_MAX_BYTES=5368709120           # 5 GiB per-artifact cap
DRIVE_UPLOAD_TTL=900                 # inactivity-based staging expiry (s)
DRIVE_DAILY_BYTES_QUOTA=21474836480  # 20 GiB per-principal-per-day
DRIVE_MAX_PENDING_UPLOADS=4
DRIVE_DISK_WATERMARK_PCT=90
DRIVE_ALLOW_EXECUTABLES=false        # PE/ELF/Mach-O rejected 415 by default

# --- Backup / DR (PLAN §9) ---
DRIVE_BACKUP_REPO=                   # restic repo (off-suite-host); operator input before Stage 7
DRIVE_BACKUP_PASSWORD_FILE=
