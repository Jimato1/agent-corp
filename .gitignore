# Dependencies
node_modules/
.pnp/
.pnp.js

# Python
.venv/
venv/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Build output
dist/
build/
.next/
out/
*.tsbuildinfo
# EXCEPTIONS: auth's build/ and ui/build/ are SOURCE-OF-TRUTH, not build output —
# build/ holds the IdP bake-off gate docs + keycloak_gates.sh; ui/build/ is the static
# operator UI the Dockerfile COPYs. Keep them tracked despite the generic build/ rule.
!platform/auth/build/
!platform/auth/build/**
!platform/auth/ui/build/
!platform/auth/ui/build/**

# Environment / secrets
.env
.env.*
!.env.example
# committed run templates (e.g. .env.internal.example); real .env.* stay ignored
!.env.*.example
*.pem
*.key

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp

# Local databases / data
*.sqlite
*.sqlite3
*.db
data/
