{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/data/**",
              "components/identity/**",
              "components/safety/**",
              "components/shell/**",
              "ui_kits/agent-runtime/**",
              "ui_kits/auth/**",
              "ui_kits/board/**",
              "ui_kits/chat/**",
              "ui_kits/cmdb/**",
              "ui_kits/drive/**",
              "ui_kits/gateway/**",
              "ui_kits/library/**",
              "ui_kits/mission-control/**",
              "ui_kits/notes/**",
              "ui_kits/vault/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Inter|JetBrains Mono|Source Serif 4))/i]",
        "message": "Font not provided by the design system. Available: Inter, JetBrains Mono, Source Serif 4."
      },
      {
        "selector": "JSXOpeningElement[name.name='AppHeader'] > JSXAttribute > JSXIdentifier[name!=/^(?:appName|identity|stateLabel|systemState|children|key|ref|className|style|children)$/]",
        "message": "<AppHeader> doesn't accept that prop. Declared props: appName, identity, stateLabel, systemState, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|size|icon|disabled|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: tone, size, icon, disabled, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:primary|secondary|ghost|danger|danger-outline)$/]",
        "message": "<Button> tone must be one of 'primary' | 'secondary' | 'ghost' | 'danger' | 'danger-outline'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:compact|default|large)$/]",
        "message": "<Button> size must be one of 'compact' | 'default' | 'large'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ConfirmFriction'] > JSXAttribute > JSXIdentifier[name!=/^(?:open|intensity|eyebrow|title|consequence|direction|irreversible|blastRadius|honest|typedIntent|stepUp|confirmLabel|auditNote|onConfirm|onCancel|onEscapeToHalt|key|ref|className|style|children)$/]",
        "message": "<ConfirmFriction> doesn't accept that prop. Declared props: open, intensity, eyebrow, title, consequence, direction, irreversible, blastRadius, honest, typedIntent, stepUp, confirmLabel, auditNote, onConfirm, onCancel, onEscapeToHalt."
      },
      {
        "selector": "JSXOpeningElement[name.name='ConfirmFriction'] > JSXAttribute[name.name='intensity'] > Literal[value!=/^(?:light|full)$/]",
        "message": "<ConfirmFriction> intensity must be one of 'light' | 'full'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ConfirmFriction'] > JSXAttribute[name.name='direction'] > Literal[value!=/^(?:more|less)$/]",
        "message": "<ConfirmFriction> direction must be one of 'more' | 'less'."
      },
      {
        "selector": "JSXOpeningElement[name.name='DangerAction'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|glyph|variant|size|disabled|intensity|title|consequence|direction|irreversible|blastRadius|honest|typedIntent|stepUp|confirmLabel|auditNote|onConfirm|onEscapeToHalt|key|ref|className|style|children)$/]",
        "message": "<DangerAction> doesn't accept that prop. Declared props: label, glyph, variant, size, disabled, intensity, title, consequence, direction, irreversible, blastRadius, honest, typedIntent, stepUp, confirmLabel, auditNote, onConfirm, onEscapeToHalt."
      },
      {
        "selector": "JSXOpeningElement[name.name='DangerAction'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:outline|solid)$/]",
        "message": "<DangerAction> variant must be one of 'outline' | 'solid'."
      },
      {
        "selector": "JSXOpeningElement[name.name='DangerAction'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:default|compact)$/]",
        "message": "<DangerAction> size must be one of 'default' | 'compact'."
      },
      {
        "selector": "JSXOpeningElement[name.name='DangerAction'] > JSXAttribute[name.name='intensity'] > Literal[value!=/^(?:light|full)$/]",
        "message": "<DangerAction> intensity must be one of 'light' | 'full'."
      },
      {
        "selector": "JSXOpeningElement[name.name='DangerAction'] > JSXAttribute[name.name='direction'] > Literal[value!=/^(?:more|less)$/]",
        "message": "<DangerAction> direction must be one of 'more' | 'less'."
      },
      {
        "selector": "JSXOpeningElement[name.name='DataColumn'] > JSXAttribute > JSXIdentifier[name!=/^(?:key|header|align|num|mono|width|sortable|render|sortValue|key|ref|className|style|children)$/]",
        "message": "<DataColumn> doesn't accept that prop. Declared props: key, header, align, num, mono, width, sortable, render, sortValue."
      },
      {
        "selector": "JSXOpeningElement[name.name='DataColumn'] > JSXAttribute[name.name='align'] > Literal[value!=/^(?:left|right)$/]",
        "message": "<DataColumn> align must be one of 'left' | 'right'."
      },
      {
        "selector": "JSXOpeningElement[name.name='EmptyState'] > JSXAttribute > JSXIdentifier[name!=/^(?:glyph|title|children|action|key|ref|className|style|children)$/]",
        "message": "<EmptyState> doesn't accept that prop. Declared props: glyph, title, children, action."
      },
      {
        "selector": "JSXOpeningElement[name.name='ErrorState'] > JSXAttribute > JSXIdentifier[name!=/^(?:pattern|title|children|detail|action|key|ref|className|style|children)$/]",
        "message": "<ErrorState> doesn't accept that prop. Declared props: pattern, title, children, detail, action."
      },
      {
        "selector": "JSXOpeningElement[name.name='ErrorState'] > JSXAttribute[name.name='pattern'] > Literal[value!=/^(?:R|D)$/]",
        "message": "<ErrorState> pattern must be one of 'R' | 'D'."
      },
      {
        "selector": "JSXOpeningElement[name.name='FenceState'] > JSXAttribute > JSXIdentifier[name!=/^(?:gen|lease|heartbeat|state|supersededBy|advisory|key|ref|className|style|children)$/]",
        "message": "<FenceState> doesn't accept that prop. Declared props: gen, lease, heartbeat, state, supersededBy, advisory."
      },
      {
        "selector": "JSXOpeningElement[name.name='FenceState'] > JSXAttribute[name.name='state'] > Literal[value!=/^(?:held|aging|superseded)$/]",
        "message": "<FenceState> state must be one of 'held' | 'aging' | 'superseded'."
      },
      {
        "selector": "JSXOpeningElement[name.name='FreshnessStamp'] > JSXAttribute > JSXIdentifier[name!=/^(?:age|state|reading|key|ref|className|style|children)$/]",
        "message": "<FreshnessStamp> doesn't accept that prop. Declared props: age, state, reading."
      },
      {
        "selector": "JSXOpeningElement[name.name='FreshnessStamp'] > JSXAttribute[name.name='state'] > Literal[value!=/^(?:live|stale|halt)$/]",
        "message": "<FreshnessStamp> state must be one of 'live' | 'stale' | 'halt'."
      },
      {
        "selector": "JSXOpeningElement[name.name='HaltBand'] > JSXAttribute > JSXIdentifier[name!=/^(?:mode|level|message|confirmed|pending|draining|pendingCountdown|drainingDetail|stillTrue|reviewHref|reviewLabel|readOnly|showTriad|key|ref|className|style|children)$/]",
        "message": "<HaltBand> doesn't accept that prop. Declared props: mode, level, message, confirmed, pending, draining, pendingCountdown, drainingDetail, stillTrue, reviewHref, reviewLabel, readOnly, showTriad."
      },
      {
        "selector": "JSXOpeningElement[name.name='HaltBand'] > JSXAttribute[name.name='mode'] > Literal[value!=/^(?:kill|safe-stop)$/]",
        "message": "<HaltBand> mode must be one of 'kill' | 'safe-stop'."
