        "selector": "JSXOpeningElement[name.name='HaltBand'] > JSXAttribute[name.name='level'] > Literal[value!=/^(?:G1|G2)$/]",
        "message": "<HaltBand> level must be one of 'G1' | 'G2'."
      },
      {
        "selector": "JSXOpeningElement[name.name='HonestState'] > JSXAttribute > JSXIdentifier[name!=/^(?:confirmed|pending|draining|pendingCountdown|drainingDetail|layout|summary|key|ref|className|style|children)$/]",
        "message": "<HonestState> doesn't accept that prop. Declared props: confirmed, pending, draining, pendingCountdown, drainingDetail, layout, summary."
