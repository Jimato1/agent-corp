# auth — environment (Stage-4). Copy to .env and edit. NEVER commit real secrets.
# The identity gateway is Critical-infra: the canonical passkey origin, the signer
# algorithm, and the token TTLs here are security-load-bearing.

# ── Suite identity / canonical origin (cross-component LOCKED) ────────────────
# The passkey origin is canonical https://auth.<SUITE_DOMAIN>:443 in BOTH modes;
# TLS + trust must be established before passkey enrollment (settled cross-comp).
SUITE_DOMAIN=suite.local
AUTH_ISSUER=https://auth.suite.local
AUTH_CANONICAL_ORIGIN=https://auth.suite.local:443
AUTH_PORT=8089
AUTH_UI_DIR=/app/ui/build

# ── Signer selection (§8.7) ──────────────────────────────────────────────────
# HS256  = stdlib TEST-signer (sandbox default; symmetric, NEVER published in JWKS).
# EdDSA  = PRODUCTION asymmetric signer (requires 'cryptography'; raises loudly if
#          absent — never a fake signature). The access-token key and the
#          X-Auth-Identity key are DISTINCT keys with separate kids + rotation.
AUTH_SIGNER_ALG=EdDSA
# Optional explicit HS256 secrets for reproducible dev (>=32 bytes). Leave blank in
# prod (EdDSA keys are generated/HSM-sealed, not set here).
AUTH_AT_SECRET=
AUTH_ID_SECRET=

# ── Token TTLs (§4.2 hybrid model) ───────────────────────────────────────────
# Short access-token TTL bounds fast-path staleness; the identity header is ~subrequest life.
AUTH_ACCESS_TTL_S=300
AUTH_IDENTITY_TTL_S=30

# ── Adopted Authorization Server: Keycloak (owns /authorize + /token) ────────
# auth-core OWNS jwks/introspect/revoke/verify/PDP/admin; Keycloak owns the OIDC
# code/token flow. CANNOT-VERIFY-HERE without the Keycloak container.
KEYCLOAK_URL=http://keycloak:8080
KEYCLOAK_REALM=agent-corp
# NOTE: compose maps these to the 26.x env names KC_BOOTSTRAP_ADMIN_USERNAME /
# KC_BOOTSTRAP_ADMIN_PASSWORD (the temp first-boot admin). keycloak_gates.sh also
# reads KEYCLOAK_ADMIN / KEYCLOAK_ADMIN_PASSWORD to authenticate kcadm.
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change-me-in-prod
# auth-core authenticates to Keycloak as this confidential client (introspect/revoke).
KEYCLOAK_CLIENT_ID=auth-core
KEYCLOAK_CLIENT_SECRET=change-me-in-prod
# Postgres DB-role password for the `keycloak` database (initdb creates the role;
# Keycloak connects with it via KC_DB_PASSWORD). Keep it single-quote-free for the
# initdb SQL string literal. MUST be consistent everywhere it appears.
KEYCLOAK_DB_PASSWORD=change-me

# ── Stage-5 MIGRATED backends (decision #8) ──────────────────────────────────
# The compose sets AUTH_STORE=postgres / AUTH_HOTSTORE=redis on the auth services;
# the factory (auth.store.factory) selects the backend. Defaults are sqlite/memory
# so the 258-test suite runs with no external services. Override for local runs:
#   AUTH_STORE=postgres|sqlite     AUTH_HOTSTORE=redis|memory
# Write-before-ack replica gate: >=1 makes each revoke WAIT for N Redis replicas and
# FAIL CLOSED if not acked (needs a Redis replica). The redis backend REFUSES to start
# with 0 unless AUTH_ALLOW_SINGLE_NODE=1 is set (see below) — the unsafe single-node
# default is a loud, explicit choice, not a silent one.
AUTH_REDIS_WAIT_REPLICAS=0
# Explicitly accept single-node Redis (no replica; AOF everysec bounds loss to <=1s).
# This is the ISOLATED GATE BOOT posture. PROD: run a Redis replica, set
# AUTH_REDIS_WAIT_REPLICAS>=1, and unset this.
AUTH_ALLOW_SINGLE_NODE=1

# ── Hot store: replicated Redis (revocation/kill/budget + auth:revocations pub/sub) ─
# Stage-5: this is the REAL HotStore (RedisHotStore). Shared by both auth replicas,
# which is what makes the kill switch cross-replica. redis-server --appendonly yes
# (AOF everysec) bounds single-node loss to <=1s.
REDIS_URL=redis://redis:6379/0

# ── Durable store: Postgres (decision #8 HA) ─────────────────────────────────
# Stage-5: this is the REAL durable Store (PostgresStore, sole writer) on the
# postgres service. In compose, DATABASE_URL's password DERIVES from POSTGRES_PASSWORD
# via nested interpolation (single source of truth — no drift). If you set an explicit
# DATABASE_URL here, its `auth` password MUST equal POSTGRES_PASSWORD.
# CANNOT-VERIFY-ON-A-LAPTOP: true multi-node DB failover (Patroni+etcd) = gate G9.
DATABASE_URL=postgresql://auth:change-me@postgres:5432/auth
# Superuser password for the postgres container (the `auth` role). Keycloak uses a
# SEPARATE `keycloak` role/password (KEYCLOAK_DB_PASSWORD above).
POSTGRES_PASSWORD=change-me
# SQLite path the current build actually uses. ":memory:" = fresh demo state seeded
# on every boot (the safe gate-boot default — no persistence conflicts on re-seed).
# A file path persists identity state but requires a writable mounted volume AND
# tolerating the demo re-seed; add that volume before switching off :memory:.
AUTH_SQLITE_PATH=:memory:

# ── Admin surface bearer (operator break-glass into /admin/*) ────────────────
# In prod the admin surface is gated by a verify'd operator session +
# auth:manage-identity; this bearer is the break-glass fallback. Rotate it.
AUTH_ADMIN_TOKEN=change-me-operator-admin

# ── Build-harness ONLY ───────────────────────────────────────────────────────
# AUTH_DEMO=1 exposes GET /debug/demo-tokens for the live curl proof and the JC-1
# joint harness (proxy regression_headers.sh mints a real agent token). NEVER in prod.
AUTH_DEMO=0
