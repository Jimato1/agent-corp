# ═════════════════════════════════════════════════════════════════════════════
# proxy env — PUBLIC mode (secondary).  TEMPLATE — copy to .env.public:
#
#     cp .env.public.example .env.public
#     # then edit .env.public: set ACME_EMAIL and a real CLOUDFLARE_API_TOKEN
#     docker compose --env-file .env.public up -d --build
#
# Public mode swaps ONLY the TLS issuer to a Let's Encrypt DNS-01 wildcard; routing,
# scrub, forward-auth, and headers are byte-identical to internal mode. This file is a
# committed TEMPLATE — the real .env.public stays gitignored. Do NOT commit a real token.
# ═════════════════════════════════════════════════════════════════════════════

# ── Mode toggle ──────────────────────────────────────────────────────────────
# IN-CONTAINER path to the public issuer partial (see the note in .env.internal.example:
# `import {$TLS_ISSUER_FILE}` resolves relative to /etc/caddy/, NOT the host).
TLS_ISSUER_FILE=/etc/caddy/issuer.public.caddy

# ── Shared routing / verify config (identical across modes) ───────────────────
# MUST equal the internal-mode SUITE_DOMAIN (passkey origin stability) AND be a real
# domain you control whose DNS is on Cloudflare, so the DNS-01 _acme-challenge TXT can
# be published for the wildcard cert.
SUITE_DOMAIN=corp.example.com

MODE_LABEL=PUBLIC

# Must match the auth service's /api/verify listen port (see .env.internal.example).
AUTH_VERIFY_PORT=9000

# ── Public-mode-REQUIRED vars ─────────────────────────────────────────────────
# ACME account email — Let's Encrypt sends expiry/recovery notices here.
ACME_EMAIL=you@example.com

# Cloudflare API token scoped to Zone:DNS:Edit for SUITE_DOMAIN's zone (used by the
# caddy-dns/cloudflare DNS-01 solver). PLACEHOLDER — replace with a real token in your
# local .env.public and NEVER commit it. Tip: use LE staging first (see issuer.public.caddy).
CLOUDFLARE_API_TOKEN=REPLACE_WITH_CLOUDFLARE_DNS_EDIT_TOKEN
