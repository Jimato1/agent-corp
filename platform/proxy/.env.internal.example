# ═════════════════════════════════════════════════════════════════════════════
# proxy env — INTERNAL mode (primary).  TEMPLATE — copy to .env.internal:
#
#     cp .env.internal.example .env.internal
#     docker compose --env-file .env.internal up -d --build
#
# Every value here is read by docker-compose.yml and passed into the proxy container,
# where conf/Caddyfile consumes it as a {$VAR} placeholder. This file is a committed
# TEMPLATE — the real .env.internal stays gitignored. Do NOT put real secrets here.
# ═════════════════════════════════════════════════════════════════════════════

# ── Mode toggle ──────────────────────────────────────────────────────────────
# Selects which TLS issuer partial the Caddyfile imports. This is an IN-CONTAINER
# PATH, not a host path: the Dockerfile COPYs the issuer partials to /etc/caddy/, and
# the Caddyfile's `import {$TLS_ISSUER_FILE}` resolves relative to /etc/caddy/ at
# runtime. A host-relative value (e.g. conf/issuer.internal.caddy) fails at boot with
# "File to import not found".
TLS_ISSUER_FILE=/etc/caddy/issuer.internal.caddy

# ── Shared routing / verify config (identical across modes) ───────────────────
# Wildcard suite domain. MUST be held IDENTICAL to the public-mode value so a passkey
# enrolled once works in both modes (WebAuthn origin = scheme+host+port; the signing CA
# is not part of the origin). Resolved on the LAN via split-horizon in internal mode
# (the test harness fakes this with `curl --resolve`).
SUITE_DOMAIN=corp.example.com

# Human-readable mode tag surfaced at the internal /edge-info endpoint. INTERNAL | PUBLIC.
MODE_LABEL=INTERNAL

# Port the auth container's /api/verify listens on (the forward-auth upstream).
# Must match the auth service's listen port; the Stage-4 auth stub reads it via PORT.
AUTH_VERIFY_PORT=9000

# ── Public-mode-only vars — UNUSED in internal mode (leave blank) ─────────────
# Internal mode uses Caddy's built-in local CA: no ACME, no Let's Encrypt, no DNS token.
# ACME_EMAIL is QUOTED in the Caddyfile, so an empty value here is valid (not an error).
ACME_EMAIL=
CLOUDFLARE_API_TOKEN=
