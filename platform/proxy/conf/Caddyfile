# ═════════════════════════════════════════════════════════════════════════════
# proxy — edge Caddyfile (Stage 4 Build).  ONE file, BOTH TLS modes.
#
# MODE SELECTION happens in exactly ONE place: `import {$TLS_ISSUER_FILE}` inside the
# wildcard site (§ issuer). Everything else — routing, header scrub, forward-auth,
# security headers, rate limiting — is byte-identical across modes. A bug in the
# less-used mode is therefore structurally impossible outside the issuer partial.
#
# Implements auth PLAN §8 (A§8.x) VERBATIM. See platform/proxy/planning/PLAN.md.
# Env (compose): TLS_ISSUER_FILE, SUITE_DOMAIN, AUTH_VERIFY_PORT, ACME_EMAIL,
#                CLOUDFLARE_API_TOKEN (public mode only).
# ═════════════════════════════════════════════════════════════════════════════

{
	# Mode-agnostic global options. Issuer-specific config lives ONLY in the
	# imported issuer partial, never here — so global is identical in both modes.
	# MUST be quoted (P4-01): Caddy env substitution is textual/pre-lex, so an
	# UNQUOTED `email {$ACME_EMAIL}` that expands empty (internal mode) becomes a
	# bare `email` with zero args → adapt error → primary mode fails to boot.
	# Quoting yields a valid empty token; internal mode has no ACME account anyway.
	email "{$ACME_EMAIL}"

	# [OBS] Prometheus metrics collection. TOP-LEVEL global option — NOT a `servers` subdirective
	# in v2.11 (that nested form is deprecated/rejected → adapt error). Metrics are SERVED only on
	# the internal :9100 listener below, never on the public :443 site. [OBS-1, web-verified]
	metrics

	servers {
		# X-Forwarded-* trust (PLAN S2-03): the proxy is the FIRST hop; operator
		# browser + agent containers connect DIRECTLY and sit in the private ranges.
		# So we DO NOT set trusted_proxies — default is trust-none → Caddy uses the
		# direct peer address for {remote_host}. Never trust private_ranges here.
		timeouts {
			# read_header: slowloris-header mitigation (Stage-5). read_body and write are
			# DELIBERATELY UNSET: read_body is a wall-clock cap on the WHOLE upload and would
			# kill legitimate large uploads (drive/pdf) + streaming request bodies; write is a
			# hard deadline on the whole response and would kill SSE/chat long-lived streams.
			# Body abuse is bounded by per-route request_body max_size instead. (Stage-5 research)
			read_header 10s
			idle        2m
		}
		# Cap request header size to blunt header-flood / oversized-header abuse (Stage-5).
		# Default is 1MB; 64KB is generous vs a Bearer JWT + session Cookie + X-Auth-Identity
		# (a few KB) yet refuses absurd header floods. Exceeding it → HTTP 431. (Stage-5 research)
		max_header_size 64KB
	}
}

# ─────────────────────────────────────────────────────────────────────────────
# Reusable snippets (shared by every route — the "byte-identical across modes" core)
# ─────────────────────────────────────────────────────────────────────────────

# (a) Security response headers — R§6.1/6.5. First in every route so it wraps every ROUTE-LEVEL
#     response, including forward-auth short-circuits (302/401/403) and the 429 from ratelimit.
#     Caveat (Stage-5 red-team): a 413 (request_body, set in the handle before the route) and a 431
#     (max_header_size, emitted by Go's HTTP server before Caddy's chain) render OUTSIDE this route,
#     so those two error pages do not carry these headers. Accepted: error pages with no body to
#     sniff/frame, over an already-established TLS connection — not an exploitable gap.
(sec_headers) {
	header {
		Strict-Transport-Security "max-age=63072000; includeSubDomains"   # no `preload` yet (R§6.1)
		X-Content-Type-Options    "nosniff"
		X-Frame-Options           "DENY"
		Referrer-Policy           "strict-origin-when-cross-origin"
		Permissions-Policy        "geolocation=(), camera=(), microphone=()"
		Content-Security-Policy   "default-src 'self'; frame-ancestors 'none'; form-action 'self'"
		-Server                                                            # strip stack fingerprint (R§6.5)
	}
}

# (b) UNCONDITIONAL inbound identity/trust/prefix scrub — A§8.6 Rule 1
#     (Caddy CVE-2026-30851 lesson). Runs on EVERY route incl. @auth (PLAN S2-01),
#     BEFORE the verify subrequest AND before upstream forwarding.
#     Header names are case-insensitive in Caddy (canonicalized), so case variants
#     are covered; underscore aliases are a DISTINCT name (CVE-2026-39858/52845) and
#     are enumerated explicitly below (Go does not fold `_`→`-`).  PLAN §12 gate #5/#6.
(scrub) {
	# dash forms (auth §8.7 set + X-Forwarded-User/Groups/Prefix + mTLS cert headers + trace)
	request_header -X-Auth-Identity
	request_header -X-Forwarded-User
	request_header -X-Forwarded-Groups
	request_header -X-Forwarded-Prefix
	request_header -Remote-User
	request_header -Remote-Groups
	request_header -Remote-Name
	request_header -Remote-Email
	request_header -X-Forwarded-Tls-Client-Cert
	request_header -X-Forwarded-Tls-Client-Cert-Thumbprint
	request_header -Traceparent
	request_header -Tracestate
	# underscore-alias twins (CVE-2026-39858 / 52845)
	request_header -X_Auth_Identity
	request_header -X_Forwarded_User
	request_header -X_Forwarded_Groups
	request_header -X_Forwarded_Prefix
	request_header -Remote_User
	request_header -Remote_Groups
	request_header -Remote_Name
	request_header -Remote_Email
	# MIXED dash/underscore variants of the 3-part names (Stage-5 red-team). Go/Caddy canonicalize
	# case only around '-'; '_' is NOT a word boundary, so X-Auth_Identity / X_Auth-Identity are
	# DISTINCT header keys from both pure forms — yet a separator-folding upstream (WSGI/CGI/nginx map
	# '-' and '_' to the SAME variable) would conflate them with the real header. Strip them too.
	request_header -X-Auth_Identity
	request_header -X_Auth-Identity
	request_header -X-Forwarded_User
	request_header -X_Forwarded-User
	request_header -X-Forwarded_Groups
	request_header -X_Forwarded-Groups
	request_header -X-Forwarded_Prefix
	request_header -X_Forwarded-Prefix
	# cert-header underscore twin (parity; mTLS not enabled yet — see NOTE re: fuller permutations)
	request_header -X_Forwarded_Tls_Client_Cert
	request_header -X_Forwarded_Tls_Client_Cert_Thumbprint
	# NOTE (PLAN S2-04, Stage-5): this is the EXPLICIT-NAMES half of A§8.6 R1. Caddy's request_header
	# has no prefix-wildcard delete, and full separator-permutation coverage of long names (the mTLS
	# cert header has 5 separators → 32 combos) is impractical by enumeration. The ULTIMATE backstop is
	# auth §8.6 R3: every RS re-validates the SIGNED X-Auth-Identity + its own aud-bound token and MUST
	# NOT authorize off a bare forwarded header. The A§8.9 regression test (test/regression_headers.sh,
	# now injecting mixed variants too) is the contract-sync gate: it MUST fail if auth's §8.7 identity
	# set grows beyond this enumeration.
}

# (c) Edge rate limiting — mholt/caddy-ratelimit (PLAN §9). Keyed on the DIRECT peer
#     ({remote_host}), NEVER {client_ip} (spoofable via X-Forwarded-For; PLAN S2-03).
#     Placement (before authgate) is fixed; numeric sizes SET in Stage 5 (below).
#
#     Zone names are GLOBAL in caddy-ratelimit: the SAME name shares ONE counter across every
#     route that imports it. So `edge_per_ip` is a single suite-wide per-IP budget (a coarse
#     DoS backstop, NOT the per-app fine limit — that is each app's own job). On limit → 429 +
#     Retry-After. Exceeding is visible via caddy-ratelimit's default Prometheus metrics.
#
#     Baseline: 600 events / 1m per source IP (~10 req/s sustained). Rationale: this ONE counter is
#     shared across all subdomains for a given IP, so it must clear an operator's single browser IP
#     loading Mission Control + several polling app tabs + per-page asset bursts, while still shedding
#     a single-IP flood (agents each have a distinct container IP, so they don't share this budget).
#     Deliberately generous because the fine per-app limit is each app's job, not the edge's. Stage-6
#     load-test lever: raise further, or switch key to `{remote_host} {host}` for a per-(IP,subdomain)
#     counter so one busy subdomain can't exhaust a client's whole suite budget.
#     RELOAD CAVEAT (Stage-5 red-team): caddy-ratelimit keeps zone state in a process-global pool keyed
#     by zone name; changing events/window and `caddy reload` keeps the OLD limiter. Re-tuning requires
#     a full `docker compose restart proxy`, not a hot reload — see optimization/NOTES.md (Stage 6).
(ratelimit) {
	rate_limit {
		zone edge_per_ip {
			key    {remote_host}
			events 600
			window 1m
		}
	}
}

# (c2) TIGHTER per-IP zone for the credential surface (the @auth login/verify subdomain), imported
#      IN ADDITION to the baseline on the @auth route only (two rate_limit handlers stack). DISTINCT
#      zone name → its OWN counter, independent of the baseline. 60 events / 1m per IP (~1 req/s) on
#      the auth host blunts credential brute-force at the edge. This is defense-in-depth: auth's own
#      §8 account lockout / revocation is the PRIMARY brute-force control; this is a coarse backstop.
(ratelimit_auth) {
	rate_limit {
		zone auth_per_ip {
			key    {remote_host}
			events 60
			window 1m
		}
	}
}

# (d) Forward-auth front door — A§8.3/8.4/8.5, implemented as the OFFICIAL `forward_auth`
#     desugaring with the success matcher tightened from `2xx` to EXACTLY `200`
#     (A§8.5: "pin exactly 200; a stray 204/206 is not allow"; PLAN §5.2c, resolves §12 gate #4).
#     - GET side-effect-free verify (A§8.3); original Authorization + Cookie forwarded
#       unchanged (reverse_proxy default) + DPoP passes through.
#     - transport timeout bounds the verify SPOF: a HUNG auth denies, not blocks (A§8.3; S2-02).
#     - On 200 ONLY: copy auth's signed X-Auth-Identity onto the ORIGINAL request (A§8.6 R2),
#       then the enclosing route continues to the real upstream.
#     - Any non-200 (302/401/403/2xx≠200/5xx/dial-error/timeout): auth's response is copied
#       back to the client and the request does NOT continue → FAIL CLOSED (A§8.5, decision #3).
(authgate) {
	reverse_proxy auth:{$AUTH_VERIFY_PORT} {
		method GET
		rewrite /api/verify
		header_up X-Forwarded-Method {method}
		header_up X-Forwarded-Uri {uri}
		header_up X-Forwarded-Host {host}       # selects the app audience at auth (A§8.3)
		transport http {
			dial_timeout            2s
			response_header_timeout 250ms
		}
		@ok status 200
		handle_response @ok {
			request_header X-Auth-Identity {rp.header.X-Auth-Identity}
			log_append authz allow   # [OBS] tags forward-auth ALLOW only; deny path UNCHANGED
			                         # (security-neutral). Denies identified by status. [VERIFY OBS-2]
		}
	}
}

# (e) Per-app site body. Order-locked by `route` (PLAN S2-05/S2-06):
#     sec_headers (outermost, wraps short-circuits) → ratelimit (shed before verify)
#     → scrub (before verify AND upstream) → authgate (verify) → reverse_proxy upstream.
#     Arg 0 = upstream host:port.
(app) {
	route {
		import sec_headers
		import ratelimit
		# [OBS] ingress-stable custom log fields (evaluated before any short-circuit, so they
		# appear on BOTH allow and deny log lines). No secrets. [VERIFY-AT-BUILD OBS-3]
		vars scrub_stripped false
		@forged_identity header X-Auth-Identity *         # '*' = match ANY value; field-only form is a parse error (OBS-3)
		vars @forged_identity scrub_stripped true
		log_append app            {http.request.host}
		log_append edge_req_id    {http.request.uuid}
		log_append scrub_stripped {http.vars.scrub_stripped}
		import scrub
		import authgate
		reverse_proxy {args[0]}
	}
}

# ─────────────────────────────────────────────────────────────────────────────
# The single wildcard site — one cert (or on-demand internal), per-host routing.
# ─────────────────────────────────────────────────────────────────────────────
*.{$SUITE_DOMAIN} {
	# ═══ THE ONE MODE-SPECIFIC LINE ═══ internal CA  |  public LE DNS-01 wildcard.
	import {$TLS_ISSUER_FILE}

	# [OBS] Structured JSON access log → stdout (Docker logs / log shipper collects it).
	# CREDENTIAL + IDENTITY REDACTION (Stage-5 hardened — CARRY-IN 2 close):
	#   REQUEST side: Caddy AUTO-redacts Authorization/Cookie by default; we also delete them +
	#     X-Auth-Identity (NOT auto-redacted — it is the auth JWT copied onto the upstream request).
	#   RESPONSE side (the Stage-5 gap): auth's verify response can carry X-Auth-Identity (a REAL
	#     signed identity JWT at Stage 7) and Remote-* principal headers into resp_headers, which
	#     Caddy does NOT auto-redact — logging them verbatim would write identity tokens to disk.
	#     Delete every token/principal-bearing response header.
	#   NOT redacted: the authoritative traceparent — it is the audit correlation key (bound to
	#     sub inside X-Auth-Identity), a non-secret we WANT for edge_req_id↔trace joins (OBSERVABILITY §2).
	#   Field-path asymmetry is LOAD-BEARING (Stage-5 research): request headers are nested
	#     (request>headers>Name); response headers are TOP-LEVEL (resp_headers>Name). Writing
	#     `response>headers>...` silently no-ops and would leak the JWT with no error.
	#   Redaction is LOG-ONLY: the filter mutates the log entry, never the wire header the app receives.
	log {
		output stdout
		format filter {
			wrap json
			fields {
				request>headers>Authorization   delete
				request>headers>Cookie          delete
				request>headers>X-Auth-Identity delete
				resp_headers>Set-Cookie         delete
				resp_headers>X-Auth-Identity    delete
				resp_headers>Remote-User        delete
				resp_headers>Remote-Groups      delete
				resp_headers>Remote-Name        delete
				resp_headers>Remote-Email       delete
				resp_headers>Authorization      delete   # DiD: real auth never returns a credential
				                                          # response header, but don't assume it (Stage-5)
			}
		}
	}

	# ---- app routes: subdomain label == auth audience segment (A§8.3; PLAN §4) ----
	# NB (Stage-5): normal app routes carry a conservative 25MB request-body cap (edge DoS
	# backstop; exceed → 413). drive/pdf override with larger caps below. Each handle holds
	# exactly ONE request_body so the "no-matcher default wraps outermost" override trap
	# (Stage-5 research) cannot silently shrink a per-route cap.
	@board host board.{$SUITE_DOMAIN}
	handle @board {
		request_body {
			max_size 25MB
		}
		import app board:8080
	}

	@notes host notes.{$SUITE_DOMAIN}
	handle @notes {
		request_body {
			max_size 25MB
		}
		import app notes:8080
	}

	@mc host mc.{$SUITE_DOMAIN}
	# audience `mc`, container `mission-control`
	handle @mc {
		request_body {
			max_size 25MB
		}
		import app mission-control:8080
	}

	@drive host drive.{$SUITE_DOMAIN}
	handle @drive {
		request_body {
			max_size 512MB                       # raised for artifact uploads (R§6.5)
		}
		import app drive:8080
	}

	@chat host chat.{$SUITE_DOMAIN}
	handle @chat {
		request_body {
			max_size 25MB
		}
		import app chat:8080
	}

	@pdf host pdf.{$SUITE_DOMAIN}
	handle @pdf {
		request_body {
			max_size 128MB
		}
		import app pdf:8080
	}

	@gateway host gateway.{$SUITE_DOMAIN}
	handle @gateway {
		request_body {
			max_size 25MB
		}
		import app gateway:8080
	}

	@vault host vault.{$SUITE_DOMAIN}
	handle @vault {
		request_body {
			max_size 25MB
		}
		import app vault:8080
	}

	@cmdb host cmdb.{$SUITE_DOMAIN}
	handle @cmdb {
		request_body {
			max_size 25MB
		}
		import app cmdb:8080
	}

	# auth is EXEMPT from the forward-auth GATE only (it self-authenticates; a gate
	# would loop login) — but NEVER from scrub or rate limiting (§ PLAN 5.4, S2-01).
	@auth host auth.{$SUITE_DOMAIN}
	handle @auth {
		route {
			import sec_headers
			import ratelimit
			import ratelimit_auth   # Stage-5: tighter credential-surface zone, stacks ON TOP of baseline
			request_body {
				max_size 25MB
			}
			import scrub
			reverse_proxy auth:{$AUTH_VERIFY_PORT}
		}
	}

	# default-deny: any unmapped subdomain (PLAN §5.3 / F7). Rate-limited too (Stage-5 red-team) so a
	# flood of nonexistent *.SUITE subdomains still hits the coarse per-IP backstop; route{} fixes
	# ratelimit-before-respond ordering.
	handle {
		route {
			import ratelimit
			respond "Not found" 404
		}
	}
}

# ─────────────────────────────────────────────────────────────────────────────
# INTERNAL-ONLY observability + health listener (plain HTTP on :9100).
#
# TRUST-BOUNDARY ENFORCEMENT (why this cannot leak or bypass auth):
#   1. :9100 is NEVER published to the host in docker-compose (no `ports:` entry) →
#      reachable ONLY by containers on the internal `edge` network (the future Mission
#      Control scraper), never from the public internet or the host.
#   2. It is a SEPARATE listener, NOT a path on the public `*.SUITE` site → it can never
#      be reached via :443, and it does not sit behind (or bypass) the forward-auth gate.
#   3. Belt-and-suspenders: refuse any non-private source IP (accurate because
#      trusted_proxies is unset → remote_ip is the direct peer). [VERIFY-AT-BUILD OBS-5]
#   4. The proxy gains NO login/authenticated surface of its own: the human sees this data
#      only via Mission Control, whose OWN subdomain sits behind the auth gate.
# ─────────────────────────────────────────────────────────────────────────────
http://:9100 {
	@internal remote_ip private_ranges
	handle @internal {
		handle /healthz {
			respond "ok" 200
		}
		handle /metrics {
			metrics                                    # native Caddy Prometheus metrics
		}
		handle /edge-info {
			header Content-Type application/json
			# Escape the leading `{` (\{) so Caddy's placeholder replacer emits it literally instead
			# of eating `{...}` as an unknown placeholder → empty body (OBS-5). The {$ENV} vars still
			# expand at parse time; {$MODE_LABEL:unknown} defaults if unset.
			respond `\{"mode":"{$MODE_LABEL:unknown}","suite_domain":"{$SUITE_DOMAIN}"}` 200
		}
		handle {
			respond "Not found" 404
		}
	}
	handle {
		respond "Forbidden" 403
	}
}
